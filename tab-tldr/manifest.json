{
  "manifest_version": 3,
  "name": "Tab TL;DR",
  "version": "1.0",
  "description": "Summarise any webpage using Chrome's built-in AI. No API key needed.",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Tab TL;DR"
  },
  "background": {
    "service_worker": "background.js"
  }
}